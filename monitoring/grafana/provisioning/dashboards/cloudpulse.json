          "expr": "sum(rate(flask_http_request_total{job=\"product-service\"}[1m]))",
          "legendFormat": "product-service",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(flask_http_request_total{job=\"order-service\"}[1m]))",
          "legendFormat": "order-service",
          "refId": "B"
        }
      ],
      "transparent": true
    },
